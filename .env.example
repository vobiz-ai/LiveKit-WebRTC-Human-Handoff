# ============================================================================
#  Backend agent configuration  --  copy to `.env` and fill in real values
#  (`.env` is gitignored; never commit real keys)
# ============================================================================

# ---- LiveKit Cloud (Project Settings -> Keys) ----
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=<your_livekit_api_key>
LIVEKIT_API_SECRET=<your_livekit_api_secret>

# ---- AI providers ----
OPENAI_API_KEY=<your_openai_key>
DEEPGRAM_API_KEY=<your_deepgram_key>

# ---- Speech models ----
TTS_PROVIDER=openai            # openai | cartesia
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_LLM_MODEL=gpt-4o-mini
# CARTESIA_API_KEY=<...>       # only if TTS_PROVIDER=cartesia
# CARTESIA_TTS_MODEL=sonic-2
# CARTESIA_TTS_VOICE=<voice_id>

# ---- Vobiz SIP trunk (used to DIAL the human into the room) ----
# Create/configure the LiveKit outbound trunk with setup_trunk.py, then paste its id here.
VOBIZ_SIP_DOMAIN=<subdomain>.sip.vobiz.ai
VOBIZ_USERNAME=<sip_username>
VOBIZ_PASSWORD=<sip_password>
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX        # caller-ID on the human leg
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxx          # LiveKit SIP outbound trunk id

# ---- Human-agent destinations ----
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
TRANSFER_SALES=+91XXXXXXXXXX
TRANSFER_BILLING=+91XXXXXXXXXX
TRANSFER_SUPPORT=+91XXXXXXXXXX

# ---- Handoff behaviour ----
#   false -> AI hard-mutes and STAYS in the room (3 participants)
#   true  -> AI disconnects after the human answers (customer <-> human go 1:1)
STEP_AWAY=false
